@model LibraryMS.Models.Auth.RegisterViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account | Library Management System</title>

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        /* ---------- MODERN PROFESSIONAL DESIGN WITH RGB COLORS & ANIMATIONS ---------- */
        :root {
            --primary-rgb: 30, 58, 95; /* Deep navy blue */
            --primary-dark-rgb: 15, 43, 68;
            --accent-rgb: 59, 130, 246; /* Bright blue accent */
            --text-primary-rgb: 30, 41, 59;
            --text-secondary-rgb: 71, 85, 105;
            --text-muted-rgb: 100, 116, 139;
            --border-light-rgb: 226, 232, 240;
            --bg-surface-rgb: 255, 255, 255;
            --bg-body-rgb: 248, 250, 252;
            --success-rgb: 16, 185, 129;
            --warning-rgb: 245, 158, 11;
            --danger-rgb: 239, 68, 68;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, rgb(var(--bg-body-rgb)) 0%, rgb(233, 238, 243) 100%);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            color: rgb(var(--text-primary-rgb));
            min-height: 100vh;
            position: relative;
            animation: fadeInBody 0.8s ease-out;
        }

            /* Subtle animated background pattern */
            body::before {
                content: '';
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-image: radial-gradient(circle at 25% 50%, rgba(var(--accent-rgb), 0.02) 0%, transparent 50%);
                pointer-events: none;
                z-index: 0;
                animation: slowShift 20s infinite alternate;
            }

        @@keyframes fadeInBody {
            0% {
                opacity: 0;
            }

            100% {
                opacity: 1;
            }
        }

        @@keyframes slowShift {
            0% {
                transform: scale(1);
                opacity: 0.6;
            }

            100% {
                transform: scale(1.1);
                opacity: 0.8;
            }
        }

        .register-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.5rem;
            position: relative;
            z-index: 1;
        }

        /* Card with entrance animation */
        .register-card {
            background: rgb(var(--bg-surface-rgb));
            border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            overflow: hidden;
            transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1), box-shadow 0.4s ease;
            border: 1px solid rgba(255, 255, 255, 0.3);
            animation: cardSlideUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
            opacity: 0;
            transform: translateY(30px);
        }

        @@keyframes cardSlideUp {
            0% {
                opacity: 0;
                transform: translateY(30px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .register-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 55px -12px rgba(0, 0, 0, 0.3);
        }

        /* Header with gradient using RGB */
        .register-header {
            background: linear-gradient(135deg, rgb(var(--primary-rgb)) 0%, rgb(var(--primary-dark-rgb)) 100%);
            padding: 2.25rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .brand-icon {
            width: 56px;
            height: 56px;
            background: rgba(255, 255, 255, 0.12);
            border-radius: 28px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.25rem;
            backdrop-filter: blur(4px);
            transition: transform 0.3s ease, background 0.3s;
            animation: pulseGlow 2s infinite;
        }

        @@keyframes pulseGlow {
            0% {
                box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.2);
            }

            70% {
                box-shadow: 0 0 0 10px rgba(255, 255, 255, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
            }
        }

        .brand-icon i {
            font-size: 1.85rem;
            color: white;
            transition: transform 0.2s;
        }

        .register-card:hover .brand-icon i {
            transform: scale(1.05);
        }

        .register-header h2 {
            font-family: 'Space Grotesk', monospace;
            font-weight: 600;
            font-size: 1.9rem;
            letter-spacing: -0.02em;
            margin-bottom: 0.5rem;
            color: white;
            animation: fadeInUp 0.5s ease-out 0.2s both;
        }

        .register-header p {
            font-size: 0.9rem;
            opacity: 0.9;
            margin-bottom: 0;
            color: rgba(255, 255, 255, 0.9);
            animation: fadeInUp 0.5s ease-out 0.3s both;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Body Content */
        .register-body {
            padding: 2.5rem 2rem;
        }

        /* Form Groups with staggered animation */
        .form-group {
            margin-bottom: 1.75rem;
            opacity: 0;
            animation: fadeSlideIn 0.4s ease-out forwards;
        }

            .form-group:nth-child(1) {
                animation-delay: 0.05s;
            }

            .form-group:nth-child(2) {
                animation-delay: 0.1s;
            }

            .form-group:nth-child(3) {
                animation-delay: 0.15s;
            }

            .form-group:nth-child(4) {
                animation-delay: 0.2s;
            }

            .form-group:nth-child(5) {
                animation-delay: 0.25s;
            }

            .form-group:nth-child(6) {
                animation-delay: 0.3s;
            }

            .form-group:nth-child(7) {
                animation-delay: 0.35s;
            }

        @@keyframes fadeSlideIn {
            from {
                opacity: 0;
                transform: translateX(-12px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            color: rgb(var(--text-secondary-rgb));
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .form-label i {
                font-size: 0.9rem;
                color: rgb(var(--primary-rgb));
                transition: color 0.2s;
            }

        /* Input field wrapper */
        .input-field-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: rgb(var(--text-muted-rgb));
            font-size: 1rem;
            pointer-events: none;
            z-index: 2;
            transition: color 0.2s ease, transform 0.2s;
        }

        .form-control-custom {
            width: 100%;
            padding: 0.8rem 1rem 0.8rem 2.5rem;
            font-size: 0.95rem;
            font-weight: 500;
            border: 1.5px solid rgb(var(--border-light-rgb));
            border-radius: 14px;
            background-color: rgb(var(--bg-surface-rgb));
            transition: all 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            color: rgb(var(--text-primary-rgb));
        }

            .form-control-custom:focus {
                border-color: rgb(var(--accent-rgb));
                box-shadow: 0 0 0 4px rgba(var(--accent-rgb), 0.15);
                outline: none;
                transform: scale(1.01);
            }

            .form-control-custom:hover {
                border-color: rgb(var(--accent-rgb));
            }

        /* Password toggle button with hover animation */
        .password-toggle {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            background: transparent;
            border: none;
            color: rgb(var(--text-muted-rgb));
            cursor: pointer;
            z-index: 3;
            padding: 0.25rem;
            transition: color 0.2s, transform 0.2s;
        }

            .password-toggle:hover {
                color: rgb(var(--primary-rgb));
                transform: translateY(-50%) scale(1.1);
            }

        /* Strength meter animation */
        .password-strength {
            margin-top: 0.75rem;
        }

        .strength-meter {
            height: 5px;
            background: rgb(var(--border-light-rgb));
            border-radius: 4px;
            overflow: hidden;
        }

        .strength-fill {
            height: 100%;
            width: 0%;
            border-radius: 4px;
            transition: width 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1), background-color 0.2s;
        }

        .strength-text {
            font-size: 0.7rem;
            font-weight: 500;
            margin-top: 0.5rem;
            text-align: right;
            color: rgb(var(--text-muted-rgb));
            transition: color 0.2s;
        }

        /* Terms checkbox with animation */
        .terms-check {
            margin: 1.75rem 0 1.5rem 0;
            padding-top: 0.5rem;
            animation: fadeSlideIn 0.4s ease-out 0.4s forwards;
            opacity: 0;
        }

        .form-check {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .form-check-input {
            width: 1.1rem;
            height: 1.1rem;
            margin-top: 0;
            border-radius: 4px;
            border: 1.5px solid rgb(var(--border-light-rgb));
            cursor: pointer;
            transition: all 0.2s;
        }

            .form-check-input:checked {
                background-color: rgb(var(--primary-rgb));
                border-color: rgb(var(--primary-rgb));
                transform: scale(1.05);
            }

        .form-check-label {
            font-size: 0.85rem;
            color: rgb(var(--text-secondary-rgb));
            font-weight: 500;
        }

            .form-check-label a {
                color: rgb(var(--primary-rgb));
                font-weight: 600;
                text-decoration: none;
                transition: color 0.2s;
            }

                .form-check-label a:hover {
                    color: rgb(var(--primary-dark-rgb));
                    text-decoration: underline;
                }

        /* Button with ripple effect animation */
        .btn-register {
            background: rgb(var(--primary-rgb));
            border: none;
            padding: 0.9rem 1.5rem;
            font-weight: 600;
            font-size: 0.95rem;
            border-radius: 40px;
            transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            width: 100%;
            color: white;
            letter-spacing: 0.01em;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            z-index: 1;
            animation: fadeSlideIn 0.4s ease-out 0.45s forwards;
            opacity: 0;
        }

            .btn-register::before {
                content: '';
                position: absolute;
                top: 50%;
                left: 50%;
                width: 0;
                height: 0;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.2);
                transform: translate(-50%, -50%);
                transition: width 0.5s, height 0.5s;
                z-index: -1;
            }

            .btn-register:hover::before {
                width: 300px;
                height: 300px;
            }

            .btn-register:hover {
                background: rgb(var(--primary-dark-rgb));
                transform: translateY(-2px);
                box-shadow: 0 10px 20px -8px rgba(var(--primary-rgb), 0.4);
            }

            .btn-register:active {
                transform: translateY(1px);
            }

        /* Login link animation */
        .login-link {
            text-align: center;
            margin-top: 1.75rem;
            font-size: 0.85rem;
            color: rgb(var(--text-secondary-rgb));
            font-weight: 500;
            animation: fadeSlideIn 0.4s ease-out 0.5s forwards;
            opacity: 0;
        }

            .login-link a {
                color: rgb(var(--primary-rgb));
                font-weight: 700;
                text-decoration: none;
                transition: all 0.2s;
                position: relative;
            }

                .login-link a::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    width: 0;
                    height: 1px;
                    background: rgb(var(--primary-rgb));
                    transition: width 0.3s ease;
                }

                .login-link a:hover::after {
                    width: 100%;
                }

        /* Validation feedback animation */
        .validation-feedback {
            font-size: 0.75rem;
            margin-top: 0.4rem;
            display: flex;
            align-items: center;
            gap: 0.25rem;
            font-weight: 500;
            animation: shakeFade 0.3s ease-out;
        }

        @@keyframes shakeFade {
            0% {
                opacity: 0;
                transform: translateX(-5px);
            }

            50% {
                transform: translateX(2px);
            }

            100% {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .text-danger {
            color: rgb(var(--danger-rgb)) !important;
        }

        /* Responsive adjustments */
        @@media (max-width: 576px) {
            .register-wrapper {
                padding: 1rem;
            }

            .register-header,
            .register-body {
                padding: 1.75rem 1.5rem;
            }

                .register-header h2 {
                    font-size: 1.5rem;
                }

            .form-control-custom {
                padding: 0.7rem 1rem 0.7rem 2.3rem;
                font-size: 0.9rem;
            }
        }
    </style>
</head>
<body>

    <div class="register-wrapper">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6 col-xl-5">
                    <div class="register-card">
                        <!-- Header with Brand Identity -->
                        <div class="register-header">
                            <div class="brand-icon">
                                <i class="bi bi-journal-bookmark-fill"></i>
                            </div>
                            <h2>Create account</h2>
                            <p>Access the Library Management Portal</p>
                        </div>

                        <!-- Registration Form -->
                        <div class="register-body">
                            <form asp-action="Register" method="post" novalidate>
                                <!-- Full Name -->
                                <div class="form-group">
                                    <label asp-for="FullName" class="form-label">
                                        <i class="bi bi-person-circle"></i>
                                        Full name
                                    </label>
                                    <div class="input-field-wrapper">
                                        <span class="input-icon"><i class="bi bi-person"></i></span>
                                        <input asp-for="FullName" class="form-control-custom" placeholder="John A. Doe" type="text" required />
                                    </div>
                                    <span asp-validation-for="FullName" class="validation-feedback text-danger"></span>
                                </div>

                                <!-- Email -->
                                <div class="form-group">
                                    <label asp-for="Email" class="form-label">
                                        <i class="bi bi-envelope-paper"></i>
                                        Email address
                                    </label>
                                    <div class="input-field-wrapper">
                                        <span class="input-icon"><i class="bi bi-envelope"></i></span>
                                        <input asp-for="Email" class="form-control-custom" placeholder="john.doe@example.com" type="email" required />
                                    </div>
                                    <span asp-validation-for="Email" class="validation-feedback text-danger"></span>
                                </div>

                                <!-- Phone Number -->
                                <div class="form-group">
                                    <label asp-for="PhoneNumber" class="form-label">
                                        <i class="bi bi-telephone"></i>
                                        Phone number
                                    </label>
                                    <div class="input-field-wrapper">
                                        <span class="input-icon"><i class="bi bi-phone"></i></span>
                                        <input asp-for="PhoneNumber" class="form-control-custom" placeholder="+1 (555) 000-9999" />
                                    </div>
                                    <span asp-validation-for="PhoneNumber" class="validation-feedback text-danger"></span>
                                </div>

                                <!-- Address -->
                                <div class="form-group">
                                    <label asp-for="Address" class="form-label">
                                        <i class="bi bi-geo-alt"></i>
                                        Address
                                    </label>
                                    <div class="input-field-wrapper">
                                        <span class="input-icon"><i class="bi bi-building"></i></span>
                                        <input asp-for="Address" class="form-control-custom" placeholder="Street, City, ZIP Code" />
                                    </div>
                                    <span asp-validation-for="Address" class="validation-feedback text-danger"></span>
                                </div>

                                <!-- Account Type (Commented as per original) -->
                                @* 
                                <div class="form-group">
                                    <label asp-for="AccountType" class="form-label">
                                        <i class="bi bi-person-badge"></i>
                                        Account Type
                                    </label>
                                    <select asp-for="AccountType" class="form-control-custom">
                                        <option value="">Select account type</option>
                                        <option value="Administrator">Administrator</option>
                                        <option value="Student">Student</option>
                                        <option value="Mangement">Mangement</option>
                                    </select>
                                    <span asp-validation-for="AccountType" class="validation-feedback text-danger"></span>
                                </div>
                                *@

                                <!-- Password Field with Strength Meter -->
                                <div class="form-group">
                                    <label asp-for="Password" class="form-label">
                                        <i class="bi bi-shield-lock"></i>
                                        Password
                                    </label>
                                    <div class="input-field-wrapper">
                                        <span class="input-icon"><i class="bi bi-key"></i></span>
                                        <input asp-for="Password" class="form-control-custom" placeholder="Create a strong password" type="password" id="password" minlength="8" required />
                                        <button type="button" class="password-toggle" id="togglePassword">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                    <!-- Strength Indicator -->
                                    <div class="password-strength">
                                        <div class="strength-meter">
                                            <div class="strength-fill" id="strengthFill"></div>
                                        </div>
                                        <div class="strength-text" id="strengthText">Password strength</div>
                                    </div>
                                    <span asp-validation-for="Password" class="validation-feedback text-danger"></span>
                                </div>

                                <!-- Confirm Password -->
                                <div class="form-group">
                                    <label asp-for="ConfirmPassword" class="form-label">
                                        <i class="bi bi-check-circle"></i>
                                        Confirm password
                                    </label>
                                    <div class="input-field-wrapper">
                                        <span class="input-icon"><i class="bi bi-lock"></i></span>
                                        <input asp-for="ConfirmPassword" type="password" class="form-control-custom" placeholder="Re-enter password" />
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="validation-feedback text-danger"></span>
                                </div>

                                <!-- Terms and Conditions -->
                                <div class="terms-check">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="termsCheck" required />
                                        <label class="form-check-label" for="termsCheck">
                                            I agree to the <a href="#" class="text-decoration-none">Terms of Service</a> and <a href="#" class="text-decoration-none">Privacy Policy</a>
                                        </label>
                                    </div>
                                </div>

                                <!-- Submit Button -->
                                <div class="d-grid mt-2">
                                    <button type="submit" class="btn-register">
                                        <i class="bi bi-person-plus-fill"></i>
                                        Create account
                                    </button>
                                </div>

                                <!-- Sign in link -->
                                <div class="login-link">
                                    Already have an account? <a asp-controller="Account" asp-action="Login">Sign in</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Toggle password visibility for main password field
        const togglePasswordBtn = document.getElementById('togglePassword');
        const passwordField = document.getElementById('password');

        if (togglePasswordBtn && passwordField) {
            togglePasswordBtn.addEventListener('click', function () {
                const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordField.setAttribute('type', type);
                const icon = this.querySelector('i');
                if (type === 'text') {
                    icon.classList.remove('bi-eye');
                    icon.classList.add('bi-eye-slash');
                } else {
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                }
            });
        }

        // Password strength meter logic
        const passwordInput = document.getElementById('password');
        const strengthFill = document.getElementById('strengthFill');
        const strengthText = document.getElementById('strengthText');

        if (passwordInput && strengthFill && strengthText) {
            passwordInput.addEventListener('input', function (e) {
                const password = e.target.value;
                let strength = 0;
                const requirements = [];

                if (password.length >= 8) strength += 25; else requirements.push('8+ characters');
                if (/[A-Z]/.test(password)) strength += 25; else requirements.push('Uppercase');
                if (/[0-9]/.test(password)) strength += 25; else requirements.push('Number');
                if (/[^A-Za-z0-9]/.test(password)) strength += 25; else requirements.push('Special char');

                strengthFill.style.width = strength + '%';

                if (strength < 25) {
                    strengthFill.style.backgroundColor = 'rgb(239, 68, 68)';
                    strengthText.textContent = 'Very weak • ' + requirements.join(', ');
                } else if (strength < 50) {
                    strengthFill.style.backgroundColor = 'rgb(249, 115, 22)';
                    strengthText.textContent = 'Weak • ' + requirements.join(', ');
                } else if (strength < 75) {
                    strengthFill.style.backgroundColor = 'rgb(234, 179, 8)';
                    strengthText.textContent = 'Medium • Add ' + requirements.join(', ');
                } else if (strength < 100) {
                    strengthFill.style.backgroundColor = 'rgb(59, 130, 246)';
                    strengthText.textContent = 'Strong • Almost there!';
                } else {
                    strengthFill.style.backgroundColor = 'rgb(16, 185, 129)';
                    strengthText.textContent = 'Excellent password';
                }

                if (password.length === 0) {
                    strengthFill.style.width = '0%';
                    strengthText.textContent = 'Password strength';
                }
            });
        }

        // Terms & Conditions validation before submit
        const regForm = document.querySelector('form');
        const termsCheckbox = document.getElementById('termsCheck');

        if (regForm && termsCheckbox) {
            regForm.addEventListener('submit', function (e) {
                if (!termsCheckbox.checked) {
                    e.preventDefault();
                    termsCheckbox.classList.add('is-invalid');
                    alert('Please accept the Terms of Service and Privacy Policy to continue.');
                } else {
                    termsCheckbox.classList.remove('is-invalid');
                }
            });
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>